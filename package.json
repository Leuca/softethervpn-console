{
  "name": "softethervpn-console",
  "version": "0.2.0-rc.7",
  "description": "A SoftEther VPN Server web management application built with PatternFly 6",
  "repository": {
    "type": "git",
    "url": "https://github.com/Leuca/softethervpn-console.git"
  },
  "homepage": "https://github.com/Leuca/softethervpn-console",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prebuild": "npm run type-check && npm run clean",
    "build": "webpack --config webpack.prod.js",
    "build:integrated": "CONSOLE_MODE=integrated npm run build",
    "build:managed": "CONSOLE_MODE=managed npm run build",
    "start": "sirv dist --single --host --port 8080",
    "start:dev": "webpack serve --color --progress --config webpack.dev.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eslint": "eslint --ext .tsx,.js ./src/ \"gateway/src/**/*.ts\"",
    "lint:ascii": "node scripts/check-ascii.mjs",
    "lint": "npm run eslint && npm run lint:ascii",
    "format": "prettier --check --write ./src/**/*.{tsx,ts}",
    "type-check": "tsc --noEmit",
    "type-check:gateway": "npm --prefix gateway run type-check",
    "type-check:all": "npm run type-check && npm run type-check:gateway",
    "ci-checks": "npm run type-check:all && npm run lint && npm run test:coverage",
    "build:bundle-profile": "webpack --config webpack.prod.js --profile --json > stats.json",
    "bundle-profile:analyze": "npm run build:bundle-profile && webpack-bundle-analyzer ./stats.json",
    "theme:gen": "node scripts/gen-dark-chrome.mjs",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.6",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "dotenv-webpack": "^8.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-webpack-plugin": "^5.6.3",
    "imagemin": "^9.0.0",
    "jsdom": "^25.0.1",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prop-types": "^15.8.1",
    "raw-loader": "^4.0.2",
    "react-axe": "^3.5.4",
    "react-router-dom": "^7.1.0",
    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.0.1",
    "style-loader": "^4.0.0",
    "svg-url-loader": "^8.0.0",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "url-loader": "^4.1.1",
    "vite": "^6.4.1",
    "vitest": "^4.0.5",
    "webpack": "^5.97.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.1",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@patternfly/react-core": "6.5.1",
    "@patternfly/react-icons": "6.5.1",
    "@patternfly/react-styles": "6.5.1",
    "@patternfly/react-table": "6.5.1",
    "@peculiar/x509": "^2.0.0",
    "react": "^18",
    "react-dom": "^18",
    "reflect-metadata": "^0.2.2",
    "sirv-cli": "^3.0.1",
    "vpnrpc": "^1.0.1"
  },
  "author": "Luca Magrone"
}
