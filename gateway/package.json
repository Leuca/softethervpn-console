{
  "name": "@softethervpn-console/gateway",
  "version": "0.2.0-rc.4",
  "description": "HTTP gateway for managed SoftEther VPN Console deployments",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --config vitest.config.ts",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/static": "^10.1.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.5"
  },
  "license": "MIT"
}
